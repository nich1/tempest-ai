# Tempest AI - environment variables.
#
# Copy this file to .env and edit values. Both apps/api and apps/consumers
# read from the same set; each binary loads only the subset it needs
# (see internal/config). The Next.js client reads its own .env.local.

# ---------- Environment marker ----------
# "dev" enables text logs and an insecure cookie. "prod" switches to JSON
# logs and Secure cookies.
API_ENV=dev

# ---------- API ----------
API_PORT=8080
COOKIE_NAME=session
# Leave COOKIE_DOMAIN empty for localhost.
COOKIE_DOMAIN=
# 7 days
SESSION_TTL=168h
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:3000
# 5 GB
MAX_FILE_SIZE_BYTES=5368709120
PRESIGNED_PUT_TTL=15m
PRESIGNED_GET_TTL=1h

# ---------- Workers ----------
WORKER_CONCURRENCY=10
QUEUE_PRIORITIES=critical:6,default:3,bulk:1
QUEUE_STRICT_PRIORITY=false
ASYNQ_RETRY_MAX=5
ASYNQ_SHUTDOWN_TIMEOUT=30s

# ---------- Postgres ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tempest
POSTGRES_USER=tempest
POSTGRES_PASSWORD=changeme
# If set, overrides the parts above.
DATABASE_URL=

# ---------- Redis (Asynq broker) ----------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- MinIO / S3 ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tempest-jobs
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ---------- LLM ----------
# Default provider:model used when a job request omits the provider field.
# Format: "<provider>:<model>". E.g. "ollama:llama3:8b", "openai:gpt-4o-mini",
# "anthropic:claude-3-5-sonnet-20241022", "gemini:gemini-1.5-pro".
LLM_PROVIDER_DEFAULT=ollama
LLM_MODEL_DEFAULT=llama3:8b
LLM_TIMEOUT=120s
# Validation retries on top of the initial call (1 means "try once more
# with the validation error message" if the first response fails the schema).
LLM_VALIDATION_RETRIES=1

OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=info
# leave empty -> json in prod, text in dev
LOG_FORMAT=
